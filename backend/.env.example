# Copy to .env and fill in your values
# Never commit .env to git

# Database (Railway provides this automatically when you add the PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@localhost:5432/calorie_tracker

# OpenAI — for Whisper transcription
OPENAI_API_KEY=sk-...

# Anthropic — for Claude calorie extraction
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# DB pool size (increase for higher traffic)
DB_POOL_MAX=10

# Rate limits
RATE_LIMIT_MAX=100
RECORD_RATE_LIMIT_MAX=10

# Logging level: error | warn | info | debug
LOG_LEVEL=info
